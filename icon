<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="100%" height="100%">
  <defs>
    <!-- Fond Dégradé Élégan-->
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#0F3D3E" />
      <stop offset="100%" stop-color="#0A2B2C" />
    </linearGradient>
    
    <!-- Dégradé Or pour les éléments clés -->
    <linearGradient id="amberGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#FFB703" />
      <stop offset="100%" stop-color="#F4A100" />
    </linearGradient>
  </defs>

  <!-- Arrière-plan Arrondi (Style Icône d'App) -->
  <rect width="512" height="512" rx="110" fill="url(#bgGrad)" />

  <!-- Lignes de Vitesse / Mobilité (Arrière du panier) -->
  <path d="M 80 230 L 140 230" stroke="url(#amberGrad)" stroke-width="12" stroke-linecap="round" opacity="0.4" />
  <path d="M 60 280 L 120 280" stroke="url(#amberGrad)" stroke-width="12" stroke-linecap="round" opacity="0.7" />
  <path d="M 90 330 L 150 330" stroke="url(#amberGrad)" stroke-width="12" stroke-linecap="round" opacity="0.4" />

  <!-- Panier de Vente / Caisse -->
  <g fill="none" stroke="#FFFFFF" stroke-linecap="round" stroke-linejoin="round">
    <!-- Poignée -->
    <path d="M 160 170 L 195 170" stroke-width="22" />
    <!-- Corps du Panier -->
    <path d="M 195 170 L 230 330 L 390 330 L 430 210 L 205 210" stroke-width="22" />
    <!-- Grillage interne du panier -->
    <path d="M 275 210 L 265 330" stroke-width="12" opacity="0.3" />
    <path d="M 345 210 L 330 330" stroke-width="12" opacity="0.3" />
    <path d="M 215 270 L 410 270" stroke-width="12" opacity="0.3" />
  </g>

  <!-- Roues Ambrées -->
  <circle cx="250" cy="390" r="28" fill="url(#amberGrad)" />
  <circle cx="250" cy="390" r="10" fill="#0A2B2C" />
  
  <circle cx="370" cy="390" r="28" fill="url(#amberGrad)" />
  <circle cx="370" cy="390" r="10" fill="#0A2B2C" />

  <!-- Éclair d'Encaissement Rapide / Check -->
  <path d="M 320 100 L 260 190 L 310 190 L 270 270 L 370 160 L 315 160 Z" 
        fill="url(#amberGrad)" 
        stroke="#0F3D3E" 
        stroke-width="6" 
        stroke-linejoin="round" />
</svg>
